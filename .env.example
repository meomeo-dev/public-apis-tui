# public-apis-cli news-flash API keys.
# Copy this file to .env and fill only the keys you have.
# Never commit .env or paste secret values into prompts, issues, or logs.

# No-auth news-flash providers:
# chroniclingamerica, hackernews, hashnode, spaceflightnews.

# API-key news-flash providers:
CURRENTS_API_KEY=
GNEWS_API_KEY=
GUARDIAN_API_KEY=
MARKETAUX_API_KEY=
MEDIASTACK_API_KEY=
NEWSAPI_API_KEY=
NEWSDATAIO_API_KEY=
NYTIMES_API_KEY=
THENEWSAPI_API_KEY=

# Agent runner credentials, such as ANTHROPIC_API_KEY or Codex provider keys,
# should live in shell startup files or a separate --agent-env-file.
